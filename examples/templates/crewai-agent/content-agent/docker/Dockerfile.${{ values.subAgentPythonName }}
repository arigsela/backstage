# ==============================================================================
# Dockerfile — ${{ values.subAgentDisplayName }} Service
# ==============================================================================
# Builds a lightweight Python container for the sub-agent.
# Same pattern as the orchestrator Dockerfile — see comments there for details.
# ==============================================================================

FROM python:3.11-slim

WORKDIR /app

# Install dependencies first (layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy shared code
COPY src/shared/ ./src/shared/

# Copy sub-agent code
COPY src/${{ values.subAgentPythonName }}/ ./src/${{ values.subAgentPythonName }}/

# Copy config files (includes knowledge sources if present)
COPY config/ ./config/

ENV PYTHONPATH=/app/src

EXPOSE ${{ values.subAgentPort }}

CMD ["uvicorn", "${{ values.subAgentPythonName }}.server:app", "--host", "0.0.0.0", "--port", "${{ values.subAgentPort }}"]
