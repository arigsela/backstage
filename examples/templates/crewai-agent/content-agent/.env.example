# ==============================================================================
# Environment Variables for ${{ values.name }}
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Docker Compose reads .env automatically. For local development without Docker,
# use: export $(cat .env | xargs)
# ==============================================================================

# --- LLM CONFIGURATION ---
# Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to use (default: claude-sonnet-4-5-20250929)
# Options: anthropic/claude-sonnet-4-5-20250929, anthropic/claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=anthropic/claude-sonnet-4-5-20250929

# --- SERVICE CONFIGURATION ---
PROJECT_NAME=${{ values.name }}
ORCHESTRATOR_PORT=${{ values.orchestratorPort }}
SUB_AGENT_PORT=${{ values.subAgentPort }}

# --- INTER-SERVICE AUTH ---
# Comma-separated API keys for A2A authentication between services.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# In production, these come from Vault. Leave empty for dev mode (no auth).
API_KEYS=

# --- SUB-AGENT URL ---
# Docker Compose: use service name. K8s: use internal DNS.
SUB_AGENT_URL=http://${{ values.subAgentName }}:${{ values.subAgentPort }}

# --- LOGGING ---
# "text" for local dev (human-readable), "json" for K8s (structured)
LOG_FORMAT=text
LOG_LEVEL=INFO

# --- CORS ---
# Comma-separated allowed origins for the orchestrator API
CORS_ORIGINS=http://localhost:3000
{% if values.enableKnowledge %}
# --- KNOWLEDGE / RAG ---
# OpenAI API key for vector embeddings (CrewAI RAG uses OpenAI embeddings
# because Anthropic does not provide an embeddings API).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Knowledge directory (where .txt, .json, .csv, .pdf files live)
# KNOWLEDGE_DIR=config/knowledge

# Embedder configuration (defaults work for most use cases)
# EMBEDDER_PROVIDER=openai
# EMBEDDER_MODEL=text-embedding-3-small
{% else %}
# --- KNOWLEDGE / RAG ---
# Knowledge/RAG is disabled. To enable it, re-scaffold with enableKnowledge: true.
# If manually enabling, you will need an OpenAI API key for embeddings:
# OPENAI_API_KEY=sk-your-openai-key-here
{% endif %}
