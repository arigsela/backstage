# ==============================================================================
# Backstage Environment Variables (.env.example)
# ==============================================================================
#
# QUICK START:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below (especially GITHUB_TOKEN)
#   3. Start services:  docker compose up -d
#   4. Start Backstage: yarn dev
#
# HOW ENV VARS WORK IN BACKSTAGE:
# Backstage config files (app-config.yaml) use ${VAR_NAME} syntax to reference
# environment variables. If a referenced var is missing, Backstage fails at startup
# with a clear error message telling you which variable is missing.
#
# NOTE ON LOCAL DEV:
# For local development, app-config.local.yaml hardcodes the database connection
# (matching docker-compose.yaml defaults), so you DON'T need to set the POSTGRES_*
# vars in .env for `yarn dev`. They're documented here for completeness and for
# production reference.
#
# SECURITY:
# The .env file is gitignored — it will never be committed to version control.
# Never put real production secrets in this file. In production (Kubernetes),
# secrets are injected via K8s Secrets / Vault / External Secrets Operator.
# ==============================================================================

# --- POSTGRESQL (Docker Compose) ---
# These are read by docker-compose.yaml to initialize the PostgreSQL container.
# They must match the values in app-config.local.yaml for Backstage to connect.
POSTGRES_DB=backstage
POSTGRES_USER=backstage
POSTGRES_PASSWORD=backstage

# --- POSTGRESQL (Backstage Config) ---
# These are read by app-config.yaml via ${POSTGRES_HOST} / ${POSTGRES_PORT}.
# For local dev with app-config.local.yaml, these are overridden by hardcoded values,
# so setting them here is optional. They're required in production.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- GITHUB INTEGRATION ---
# Personal Access Token (PAT) for GitHub API access.
# Used by: Catalog (reading YAML from repos), Scaffolder (creating repos),
# TechDocs (fetching docs), and Catalog Import.
#
# Create one at: https://github.com/settings/tokens
# Required scopes:
#   - repo          (read access to private repositories)
#   - read:org      (read organization members and teams)
#   - workflow       (optional: needed if Scaffolder creates workflows)
GITHUB_TOKEN=ghp_your_token_here

# --- GITHUB OAUTH (Authentication) ---
# These are from a GitHub OAuth App (NOT the same as the Personal Access Token above).
# The PAT above is for Backstage's server-side API calls (reading repos, creating PRs).
# The OAuth App below is for user sign-in (authenticating users via the browser).
#
# Create an OAuth App at: https://github.com/settings/developers → "OAuth Apps"
#   - Homepage URL: http://localhost:3000
#   - Authorization callback URL: http://localhost:7007/api/auth/github/handler/frame
#
# NOTE: For local dev, you can also put these in app-config.local.yaml instead.
# In production (Kubernetes), these are injected via K8s Secrets.
AUTH_GITHUB_CLIENT_ID=your_github_oauth_client_id
AUTH_GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# --- KUBERNETES (Production Only) ---
# These are used by the Kubernetes plugin to connect to your cluster's API server.
# For LOCAL DEV, these are NOT needed — app-config.local.yaml uses localKubectlProxy
# which connects through `kubectl proxy` using your local kubeconfig.
#
# In production (Kubernetes), these are injected via K8s Secrets:
#   K8S_CLUSTER_URL: Your Kubernetes API server URL (e.g., https://10.0.1.50:6443)
#   K8S_SERVICE_ACCOUNT_TOKEN: A ServiceAccount token with read access to the cluster
#
# To get a ServiceAccount token:
#   1. Create a ServiceAccount: kubectl create sa backstage-k8s-reader -n backstage
#   2. Create a ClusterRoleBinding for read access
#   3. Create a long-lived token: kubectl create token backstage-k8s-reader -n backstage --duration=8760h
K8S_CLUSTER_URL=https://your-k8s-api-server:6443
K8S_SERVICE_ACCOUNT_TOKEN=your_service_account_token_here
